      <aliases enabled='yes' />
      <column caption='Accounts Payable' datatype='integer' name='[Accounts_Payable]' role='measure' type='quantitative' />
      <column caption='Accounts Receivable' datatype='integer' name='[Accounts_Receivable]' role='measure' type='quantitative' />
      <column caption='Allowable DSH Percentage' datatype='real' name='[Allowable_DSH_Percentage]' role='measure' type='quantitative' />
      <column caption='CCN Facility Type' datatype='string' name='[CCN_Facility_Type]' role='dimension' type='nominal' />
      <column caption='Total Revenue from Low Income Health Insurance' datatype='integer' name='[Calculation_0188905763557376]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Net_Revenue_from_Medicaid] + [Net_Revenue_from_Stand_Alone_CHIP]' />
      </column>
      <column caption='Overall Profitability' datatype='real' name='[Calculation_0188905774714881]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Total_Income] - [Total_Costs]' />
      </column>
      <column caption='Cost to Income Ratio' datatype='real' name='[Calculation_0188905779961858]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Total_Costs]/[Total_Income]' />
      </column>
      <column caption='Income per Bed' datatype='real' name='[Calculation_0970380872630272]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Net_Income]) / ([Number_of_Beds])' />
      </column>
      <column caption='Income per Bed Status' datatype='string' name='[Calculation_1557520202088449]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_0970380872630272] &lt; 0 THEN &quot;In debt per bed&quot;&#13;&#10;ELSE &quot;In revenue per bed&quot;&#13;&#10;END' />
      </column>
      <column caption='Cash on Hand and in Banks' datatype='integer' name='[Cash_on_Hand_and_in_Banks]' role='measure' type='quantitative' />
      <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
